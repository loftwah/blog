---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `${SITE_TITLE} — On pause`;
const pageDescription = 'This site is quiet for now.';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={pageTitle} description={pageDescription} />
  </head>
  <body class="bg-gray-950 text-gray-50">
    <main class="relative min-h-screen flex items-center justify-center px-6 py-16">
      <div class="absolute inset-0">
        <img
          src="/images/loftwah_banner.jpg"
          alt=""
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/65"></div>
      </div>

      <section class="relative z-10 max-w-xl text-center">
        <div class="mx-auto mb-6 h-24 w-24 rounded-full overflow-hidden border border-white/30 shadow-lg">
          <img
            src="/android-chrome-512x512.png"
            alt="Dean Loftwah Lofts"
            class="h-full w-full object-cover"
          />
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">Taking a pause.</h1>
        <p class="mt-4 text-base sm:text-lg text-white/85">
          I lost my job and it made me rethink everything, including tech. This space is quiet for now.
        </p>
        <p class="mt-6 text-sm text-white/70">Thanks for stopping by.</p>
      </section>
    </main>
  </body>
</html>
